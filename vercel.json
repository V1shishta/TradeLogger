{
  "version": 2,
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python",
      "config": { "includeFiles": "backend/**" }
    },
    { "src": "frontend/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/index.py" },
    { "src": "/", "dest": "/frontend/index.html" },
    { "src": "/favicon.svg", "dest": "/frontend/assets/favicon.svg" },
    { "src": "/(css|js|assets)/(.+)", "dest": "/frontend/$1/$2" },
    { "src": "/((?!_vercel/).+)", "dest": "/frontend/index.html" }
  ]
}
